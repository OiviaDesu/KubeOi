# Oiviak3s Operator Configuration Template
# Copy this file to .env and customize for your environment
# IMPORTANT: Do NOT commit .env to version control
# Sensitive values (tokens, keys) should use Kubernetes Secrets instead

# ============================================================================
# Cluster Configuration
# ============================================================================
CLUSTER_REGION_HANOI=hanoi
CLUSTER_REGION_MELBOURNE=melbourne

# ============================================================================
# SENSITIVE: Use Kubernetes Secrets or .env.local for these values
# See config/manager/secret.yaml.example
# ============================================================================
# ZeroTier network configuration - DO NOT HARDCODE
ZEROTIER_NETWORK_ID=your-zerotier-network-id-here

# ============================================================================
# Node Configuration - Can be in .env
# ============================================================================
# Node IP mappings (ZeroTier fixed IPs) - these are internal network IPs
NODE_X509FJ_IP=192.168.86.8
NODE_MACMINI_IP=192.168.86.4
NODE_PI400_IP=192.168.86.40
ZEROTIER_INTERFACE=zt0

# Hostname mappings for SSH access
# These are used by control-plane-failover.sh
PRIMARY_HOST=oiviax509fj-master
MAC_HOST=oiviamacmini-worker
PI_HOST=oiviapi-worker
SSH_USER=oiviadesu

# ============================================================================
# Health Check Configuration
# ============================================================================
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
FAILOVER_THRESHOLD=3

# ============================================================================
# Notification Configuration - SENSITIVE
# ============================================================================
# These should be in Kubernetes Secrets, not .env
# Use config/manager/secret.yaml instead
# TELEGRAM_BOT_TOKEN=your-token-here
# TELEGRAM_CHAT_ID=your-chat-id-here
# DISCORD_WEBHOOK_URL=your-webhook-url-here
NOTIFICATION_ENABLED=true

# ============================================================================
# Placement Configuration
# ============================================================================
PLACEMENT_STRATEGY=geographic
DEFAULT_REGION_PREFERENCE=hanoi

# ============================================================================
# Metrics Configuration
# ============================================================================
METRICS_BIND_ADDRESS=:8080
HEALTH_PROBE_BIND_ADDRESS=:8081

# ============================================================================
# Leader Election
# ============================================================================
LEADER_ELECT=true

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
