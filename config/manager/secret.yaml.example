apiVersion: v1
kind: Secret
metadata:
  name: oiviak3s-config
  namespace: oiviak3s-system
type: Opaque
stringData:
  # ========================================================================
  # SENSITIVE CONFIGURATION - Keep this file out of version control
  # ========================================================================
  # This file should NOT be committed to Git. Use it as a template to create
  # the actual Secret in your cluster using:
  #   kubectl apply -f config/manager/secret.yaml
  # ========================================================================
  
  # ZeroTier Network ID - Required
  # Join your ZeroTier network for multi-site connectivity
  # Get this from your ZeroTier account dashboard
  zerotier-network-id: "YOUR_ZEROTIER_NETWORK_ID_HERE"
  
  # Telegram Bot Configuration - Optional for notifications
  # Create a bot via @BotFather on Telegram and get your token
  # Bot token format: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
  telegram-bot-token: "YOUR_TELEGRAM_BOT_TOKEN_HERE"
  
  # Telegram Chat ID - Required with telegram-bot-token
  # Get this via the @userinfobot or similar utility
  # Should be a numeric ID: 123456789
  telegram-chat-id: "YOUR_TELEGRAM_CHAT_ID_HERE"
  
  # Discord Webhook URL - Optional for notifications
  # Create a webhook in your Discord server and paste the full URL
  # Format: https://discordapp.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
  discord-webhook-url: "YOUR_DISCORD_WEBHOOK_URL_HERE"
